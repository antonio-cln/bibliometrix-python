@ARTICLE{Park2026,
	author = {Park, Juwon and Cho, Soyoung and Lee, Hyundo and Choi, Yo rim and Choi, Dong-Hwa and Jeong, Mi-Young and Lim, Yun-Sook and Hwang, Soon B. and Choi, Jiwon},
