@ARTICLE{Li2026,
	author = {Li, Zhao and Xi, Dexiang and Chen, Shaobin and Wang, Yongjian and Xie, Chunyang and Sun, Xilei and Tian, Hua and Long, Wuqiang},
	title = {Fuel economy and emission optimization of spark-ignition pure methanol engine based on gradient boosting neural network and many-objective Bayesian optimization},
	year = {2026},
	journal = {Fuel},
	volume = {426},
	pages = {},
	doi = {10.1016/j.fuel.2026.139573},
	url = {https://www.scopus.com/pages/publications/105036427295?origin=resultslist},
	affiliations = {School of Energy and Power Engineering, Dalian University of Technology, Dalian, 116024, China},
	abstract = {Achieving efficient and clean operation of spark-ignition pure methanol engines remains a central challenge for their deployment in low-carbon transportation. To address this challenge effectively, an integrated framework that combines high-fidelity simulation, machine learning surrogate modeling and many-objective cooperative optimization is proposed in this study. A multi-physics coupled simulation model for a methanol engine was established and rigorously calibrated against experimental data, and a high-precision, computationally efficient Gradient Boosting Neural Network (GBNN) model was developed. On this basis, the Many-objective Bayesian Optimization (MaOBO) algorithm was proposed to achieve comprehensive optimization of fuel-economy and emission performance. The results show that GBNN model demonstrates exceptional accuracy and generalization capability, achieving coefficients of determination (R<sup>2</sup>) of 0.905, 0.967, 0.922 and 0.939 for predictions of brake specific fuel consumption (BSFC), nitrogen oxides (NO<sub>x</sub>), hydrocarbons (HC) and carbon dioxide (CO<sub>2</sub>), respectively. MaOBO outperforms traditional methods in convergence speed, uniformity of Pareto front (PF) distribution and robustness, and the global optimal solution reduces BSFC, NO<sub>x</sub>, HC and CO<sub>2</sub> by 4.29%, 21.01%, 32.19% and 3.59%, achieving the best balance between economic and emission characteristics. A computational cost analysis shows that replacing direct optimization driven by GT-Power evaluations (∼1.0 × 10<sup>5</sup> min) with the proposed framework reduces the same-scale evaluation time to ∼5 min, thereby enabling practical many-objective global search and rapid design-space iteration. These findings provide a computationally efficient and practical pathway for performance optimization of pure methanol engines, offering significant guidance for development and application of clean-fuel engines. © 2026 Elsevier Ltd.},
	author_keywords = {GBNN; Many-objective optimization; MaOBO; Multi-physics coupled simulation; Pure methanol engine},
