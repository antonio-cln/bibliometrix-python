	title = {Physics-based machine learning toolbox for probing concentration under diffusive regime in microfluidics devices},
	year = {2026},
	journal = {Communications Physics},
	volume = {9},
	number = {1},
	pages = {},
	doi = {10.1038/s42005-026-02590-y},
	url = {https://www.scopus.com/pages/publications/105035151629?origin=resultslist},
	affiliations = {Institute of Fusion Energy and Nuclear Waste Management (IFN)—Nuclear Waste Management (IFN-2), Forshungszentrum Jülich GmbH, Jülich, Germany; Advanced Space Propulsion and Energy Laboratory (ASPEL), School of Astronautics, Beihang University, Beijing, China},
	abstract = {Microfluidics experiments offer high-resolution insights into transport and chemical processes in porous media, yet direct measurement of evolving concentration profiles remains challenging. Numerical simulations can serve as virtual probes but are labor-intensive and computationally expensive. Here, we develop a physics-based machine learning toolbox that transforms such simulations into efficient and scalable virtual probes. Central to our toolbox is the non-intrusive reduced basis method, supported by the U-Net and the Convolutional Autoencoder, which learns mappings from experimental images and physical parameters to concentration profiles. By incorporating physics into its construction, the toolbox delivers accurate predictions with a limited number of training samples. Applied to two microfluidics experiments with different base patterns, the toolbox predicts spatio-temporal concentration profiles, effective diffusivities, and locations with a high probability of precipitation. This paves the way for digital twins that enable real-time analysis and tuning of experiments on the fly. © The Author(s) 2026.},
	keywords = {Digital twin; Learning systems; Machine learning; Microfluidics; Probes; Sampling; Chemical process; Concentration profiles; Diffusive regime; High resolution; Machine-learning; Microfluidics devices; Physics-based; Porous medium; Transport process; Virtual probes; Porous materials},
	correspondence_address = {R. Santoso; Institute of Fusion Energy and Nuclear Waste Management (IFN)—Nuclear Waste Management (IFN-2), Forshungszentrum Jülich GmbH, Jülich, Germany; email: r.santoso@fz-juelich.de},
	publisher = {Nature Research},
	issn = {23993650},
	language = {English},
	abbrev_source_title = {Commun. Phys.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Sankhyan2026,
	author = {Sankhyan, Sahil and Sharma, Shreya and pohal, Sangeeta and Uday, Kala Venkata and Dutt, Varun},
