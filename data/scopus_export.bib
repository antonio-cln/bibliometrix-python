@ARTICLE{Johnson2026,
	author = {Johnson, Marcela A. and Nieves-Rodriguez, Shirley and Hou, Liping and Huang, Bevan Emma and Saadatpour, Assieh and Doostparast Torshizi, Abolfazl},
	title = {Machine learning-based proteogenomic data modeling identifies circulating plasma biomarkers for early detection of lung cancer},
	year = {2026},
