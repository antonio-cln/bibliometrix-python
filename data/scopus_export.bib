@ARTICLE{Gu2026,
	author = {Gu, Jiaping and Chai, Jiale},
	title = {An interpretable machine learning model for prediction of significant liver fibrosis in comorbid chronic hepatitis B and nonalcoholic fatty liver disease: a retrospective development and validation study},
